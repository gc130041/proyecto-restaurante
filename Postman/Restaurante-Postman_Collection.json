                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Iniciar sesión",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "let data = {};",
                  "try { data = pm.response.json(); } catch (e) {}",
                  "const token = data?.token;",
                  "pm.test('Token recibido', function () {",
                  "  pm.expect(token).to.be.a('string').and.not.empty;",
                  "});",
                  "if (token) pm.collectionVariables.set('token', token);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"correoejemplo@mail.com\",\n  \"password\": \"test123!\"\n}"
            },
            "url": {
